<DocsLayout title="MCP Server — EarlyPass Docs" activeDoc="mcp">
  <Fragment slot="head-meta">
    <meta name="description" content="Connect Claude Desktop, Cursor, or any MCP client to EarlyPass and manage waitlist campaigns with AI.">

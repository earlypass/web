---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="EarlyPass — Drop-in viral waitlist for your next launch">
  <Fragment slot="head-meta">
    <meta name="description" content="Add referral tracking, a leaderboard, and milestone rewards to your waitlist with a single script tag. Open source, API-first, self-hostable.">
    <meta name="keywords" content="waitlist widget, viral waitlist, referral waitlist, launch waitlist tool, open source waitlist">
    <link rel="canonical" href="https://www.earlypass.app/">

    <!-- Open Graph -->
    <meta property="og:type" content="website">
    <meta property="og:url" content="https://www.earlypass.app/">
    <meta property="og:title" content="EarlyPass — Drop-in viral waitlist for your next launch">
    <meta property="og:description" content="Add referral tracking, a leaderboard, and milestone rewards to your waitlist with a single script tag. Open source, self-hostable.">
    <meta property="og:image" content="https://www.earlypass.app/og-image.png">

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image">
    <meta name="twitter:title" content="EarlyPass — Drop-in viral waitlist for your next launch">
    <meta name="twitter:description" content="Add referral tracking, a leaderboard, and milestone rewards to your waitlist with a single script tag.">
    <meta name="twitter:image" content="https://www.earlypass.app/og-image.png">
  </Fragment>

  <Fragment slot="head-extra">
    <style>
/* ── Hero ───────────────────────────────── */
.hero {
  background: linear-gradient(150deg, #f0f0ff 0%, var(--surface) 55%);
  padding: 80px 24px 64px;
  text-align: center;
}
.hero-badge {
  display: inline-block;
  background: var(--primary-light);
  color: var(--primary);
  border: 1px solid #c7d2fe;
  border-radius: 99px;
  font-size: 12px;
  font-weight: 600;
  padding: 4px 12px;
  margin-bottom: 24px;
  letter-spacing: 0.02em;
}
.hero h1 {
  font-size: clamp(2.25rem, 5vw, 3.25rem);
  font-weight: 800;
  line-height: 1.15;
  margin-bottom: 20px;
  letter-spacing: -0.02em;
}
.hero h1 span { color: var(--primary); }
.hero p {
  font-size: 19px;
  color: var(--muted);
  max-width: 560px;
  margin: 0 auto 36px;
  line-height: 1.65;
}
.hero-btns { display: flex; gap: 12px; justify-content: center; flex-wrap: wrap; }

/* ── Demo section ───────────────────────── */
.demo-section {
  padding: 80px 24px;
  background: var(--bg);
}
.demo-inner {
  max-width: 1080px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: minmax(0, 1fr) minmax(0, 1fr);
  gap: 48px;
  align-items: start;
}
@media (max-width: 768px) {
  .demo-inner { grid-template-columns: 1fr; }
}
.demo-label {
  font-size: 13px;
  font-weight: 600;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  color: var(--primary);
  margin-bottom: 8px;
}
.demo-section h2 { font-size: 1.75rem; font-weight: 700; margin-bottom: 12px; }
.demo-section p { color: var(--muted); margin-bottom: 24px; line-height: 1.65; }
.demo-widget-wrap {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 24px;
}
.code-block {
  background: var(--code-bg);
  color: var(--code-text);
  font-family: ui-monospace, "Cascadia Code", "Fira Code", monospace;
  font-size: 13px;
  padding: 20px 24px;
  border-radius: var(--radius);
  line-height: 1.7;
  overflow-x: auto;
  white-space: pre;
}
.code-comment { color: #94a3b8; }
.code-attr { color: #93c5fd; }
.code-val { color: #86efac; }
.code-tag { color: #f9a8d4; }

/* ── Features ───────────────────────────── */
.features {
  padding: 80px 24px;
}
.features h2 {
  font-size: 1.75rem;
  font-weight: 700;
  text-align: center;
  margin-bottom: 12px;
}
.features .section-lead {
  text-align: center;
  color: var(--muted);
  font-size: 17px;
  max-width: 520px;
  margin: 0 auto 48px;
  line-height: 1.6;
}
.feature-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
  gap: 24px;
  max-width: 1080px;
  margin: 0 auto;
}
.feature {
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 24px;
  transition: box-shadow 0.2s;
}
.feature:hover { box-shadow: 0 4px 16px rgba(0,0,0,0.07); }
.feature-icon {
  width: 40px; height: 40px;
  background: var(--primary-light);
  border-radius: 10px;
  display: flex; align-items: center; justify-content: center;
  font-size: 20px;
  margin-bottom: 14px;
}
.feature h3 { font-size: 15px; font-weight: 600; margin-bottom: 8px; }
.feature p { font-size: 14px; color: var(--muted); line-height: 1.6; }

/* ── Self-hosting ───────────────────────── */
.selfhost {
  padding: 80px 24px;
  background: var(--bg);
}
.selfhost .container { max-width: 820px; }
.selfhost h2 { font-size: 1.75rem; font-weight: 700; margin-bottom: 12px; }
.selfhost p { color: var(--muted); margin-bottom: 24px; line-height: 1.6; }

/* ── Developer ──────────────────────────── */
.developer {
  padding: 80px 24px;
}
.developer h2 { font-size: 1.75rem; font-weight: 700; margin-bottom: 12px; text-align: center; }
.developer .section-lead {
  text-align: center; color: var(--muted); font-size: 17px;
  max-width: 480px; margin: 0 auto 48px; line-height: 1.6;
}
.dev-links {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  justify-content: center;
  max-width: 700px;
  margin: 0 auto;
}
.dev-link {
  display: flex; align-items: center; gap: 10px;
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: var(--radius-lg);
  padding: 16px 20px;
  text-decoration: none;
  transition: box-shadow 0.2s, border-color 0.2s;
  min-width: 200px; flex: 1;
}
.dev-link:hover { border-color: var(--primary); box-shadow: 0 2px 12px rgba(79,70,229,0.1); text-decoration: none; }
.dev-link-icon {
  width: 36px; height: 36px;
  background: var(--primary-light);
  border-radius: 8px;
  display: flex; align-items: center; justify-content: center;
  font-size: 18px;
  flex-shrink: 0;
}
.dev-link-text strong { display: block; font-size: 14px; font-weight: 600; color: var(--text); }
.dev-link-text span { font-size: 12px; color: var(--muted); }

/* ── CTA banner ─────────────────────────── */
.cta-banner {
  padding: 80px 24px;
  background: var(--primary);
  text-align: center;
  color: #fff;
}
.cta-banner h2 { font-size: 1.75rem; font-weight: 700; margin-bottom: 12px; }
.cta-banner p { font-size: 17px; opacity: 0.85; margin-bottom: 32px; }
.cta-banner .btn-primary {
  background: #fff;
  color: var(--primary);
}
.cta-banner .btn-primary:hover { background: #eef2ff; }
.cta-banner .btn-secondary {
  background: transparent;
  color: #fff;
  border-color: rgba(255,255,255,0.4);
}
.cta-banner .btn-secondary:hover { background: rgba(255,255,255,0.1); }
    </style>
  </Fragment>

  <section class="hero">
    <span class="hero-badge">Open Source · BSL License · Self-Hostable</span>
    <h1>Drop-in viral waitlist<br>for your <span>next launch</span></h1>
    <p>Add referral tracking, a leaderboard, and milestone rewards to your waitlist with a single script tag. No backend changes required.</p>
    <div class="hero-btns">
      <a href="https://api.earlypass.app/dashboard/login" class="btn btn-primary btn-lg">Get started free →</a>
      <a href="https://github.com/earlypass/earlypass" target="_blank" rel="noopener" class="btn btn-secondary btn-lg">View on GitHub</a>
    </div>
  </section>

  <section class="demo-section">
    <div class="demo-inner">
      <div>
        <div class="demo-label">Live demo</div>
        <h2>See it in action</h2>
        <p>This is a real EarlyPass widget connected to a live campaign. Sign up to see your referral link and position on the leaderboard.</p>
        <div class="demo-widget-wrap">
          <script src="https://api.earlypass.app/widget/widget.js" data-campaign="6dlgv6n59s"></script>
        </div>
      </div>
      <div>
        <div class="demo-label">One script tag</div>
        <h2>Paste once. Done.</h2>
        <p>Drop this into your landing page and EarlyPass handles everything: email collection, referral codes, position tracking, and leaderboard.</p>
        <div class="code-block" set:html={`<span class="code-tag">&lt;script</span>
  <span class="code-attr">src</span>=<span class="code-val">"https://api.earlypass.app/widget/widget.js"</span>
  <span class="code-attr">data-campaign</span>=<span class="code-val">"my-product"</span>
  <span class="code-attr">async</span>
<span class="code-tag">&gt;&lt;/script&gt;</span>`}></div>
        <p style="margin-top:20px;font-size:14px;color:var(--muted);">
          No npm install. No build step. Loads asynchronously so it never blocks your page.
          <a href="/docs/widget">Widget customization →</a>
        </p>
      </div>
    </div>
  </section>

  <section class="features">
    <div class="container">
      <h2>Everything your waitlist needs</h2>
      <p class="section-lead">Built for founders who want growth mechanics without building them from scratch.</p>
      <div class="feature-grid">
        <div class="feature">
          <div class="feature-icon">🔗</div>
          <h3>Referral tracking</h3>
          <p>Every signup gets a unique referral link. The widget shows it immediately after sign-up — no extra steps, no friction.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">🏆</div>
          <h3>Live leaderboard</h3>
          <p>Show who's winning and let signups compete for priority access. Transparent mechanics build trust: your position is explained right in the widget.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">📊</div>
          <h3>Analytics dashboard</h3>
          <p>Real-time signup trends, viral coefficient, referral rate, and conversion data. See which channels are driving growth.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">🤖</div>
          <h3>API-first + MCP</h3>
          <p>Full REST API and a hosted MCP server — manage campaigns from Claude, Cursor, or any MCP-compatible AI assistant.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">📬</div>
          <h3>Access granting</h3>
          <p>Invite your top referrers with one click. Each invite includes a personalised token your product can verify and redeem.</p>
        </div>
        <div class="feature">
          <div class="feature-icon">🔒</div>
          <h3>Open source &amp; self-hostable</h3>
          <p>BSL licensed — free to self-host forever. Deploy to Kubernetes with our Helm chart or to any VPS with Docker Compose.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="selfhost">
    <div class="container">
      <h2>Own your data</h2>
      <p>EarlyPass is open source under the Business Source License. Self-host on your own infrastructure — your waitlist data never touches our servers.</p>
      <div class="code-block" style="font-size:12px;margin-top:24px;">helm install earlypass \
  oci://ghcr.io/earlypass/charts/earlypass \
  --set secrets.databaseUrl="postgres://..."</div>
      <a href="/docs/getting-started" style="font-size:13px;margin-top:12px;display:inline-block;">Full setup guide →</a>
    </div>
  </section>

  <section class="developer">
    <div class="container">
      <h2>Built for developers</h2>
      <p class="section-lead">Spec-first REST API, OpenAPI docs, webhooks, and a hosted MCP server for AI-driven campaign management.</p>
      <div class="dev-links">
        <a href="/docs/getting-started" class="dev-link">
          <span class="dev-link-icon">🚀</span>
          <span class="dev-link-text">
            <strong>Getting Started</strong>
            <span>Create your first campaign</span>
          </span>
        </a>
        <a href="/docs/api" class="dev-link">
          <span class="dev-link-icon">📄</span>
          <span class="dev-link-text">
            <strong>API Reference</strong>
            <span>Interactive REST docs</span>
          </span>
        </a>
        <a href="/docs/widget" class="dev-link">
          <span class="dev-link-icon">🧩</span>
          <span class="dev-link-text">
            <strong>Widget Docs</strong>
            <span>Attributes &amp; theming</span>
          </span>
        </a>
        <a href="/docs/mcp" class="dev-link">
          <span class="dev-link-icon">🤖</span>
          <span class="dev-link-text">
            <strong>MCP Server</strong>
            <span>Claude &amp; Cursor integration</span>
          </span>
        </a>
        <a href="https://github.com/earlypass/earlypass" target="_blank" rel="noopener" class="dev-link">
          <span class="dev-link-icon">⭐</span>
          <span class="dev-link-text">
            <strong>GitHub</strong>
            <span>Source code &amp; issues</span>
          </span>
        </a>
      </div>
    </div>
  </section>

  <section class="cta-banner">
    <div class="container">
      <h2>Ready to launch?</h2>
      <p>Set up your waitlist in minutes. No credit card required.</p>
      <div style="display:flex;gap:12px;justify-content:center;flex-wrap:wrap;">
        <a href="https://api.earlypass.app/dashboard/login" class="btn btn-primary btn-lg">Get started free</a>
        <a href="/docs/getting-started" class="btn btn-secondary btn-lg">Read the docs</a>
      </div>
    </div>
  </section>
</BaseLayout>
